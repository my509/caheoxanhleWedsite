<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>💕 Kỷ Niệm 2 Năm - Tình Yêu Của Chúng Ta</title>
    <meta name="description" content="Kỷ niệm 2 năm yêu nhau - 24/04/2024">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #0c0c1d 0%, #1a1a2e 50%, #16213e 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
            position: relative;
        }

        /* Stars background */
        .stars {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .star {
            position: absolute;
            width: 2px;
            height: 2px;
            background: white;
            border-radius: 50%;
            animation: twinkle 2s infinite;
        }

        .container {
            position: relative;
            text-align: center;
            z-index: 2;
            padding: 20px;
        }

        /* Loading screen */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0c0c1d;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            animation: fadeOut 1s ease 2s forwards;
        }

        .loading-heart {
            font-size: 50px;
            animation: loadingPulse 0.8s ease-in-out infinite;
        }

        /* Heart styles */
        .heart-wrapper {
            position: relative;
            margin: 0 auto 30px;
        }

        .heart {
            position: relative;
            width: 200px;
            height: 200px;
            margin: 0 auto;
            animation: heartBeat 1.2s ease-in-out infinite;
            filter: drop-shadow(0 0 20px rgba(255, 0, 100, 0.8))
                   drop-shadow(0 0 40px rgba(255, 0, 100, 0.6))
                   drop-shadow(0 0 80px rgba(255, 0, 100, 0.4));
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .heart:hover {
            filter: drop-shadow(0 0 30px rgba(255, 0, 100, 1))
                   drop-shadow(0 0 60px rgba(255, 0, 100, 0.8))
                   drop-shadow(0 0 100px rgba(255, 0, 100, 0.6));
            transform: scale(1.05);
        }

        .heart::before,
        .heart::after {
            content: '';
            position: absolute;
            width: 100px;
            height: 160px;
            background: linear-gradient(135deg, #ff6b9d, #ff1744);
            border-radius: 50px 50px 0 0;
            box-shadow: inset 0 -10px 20px rgba(0,0,0,0.2);
        }

        .heart::before {
            left: 100px;
            top: 0;
            transform: rotate(-45deg);
            transform-origin: 0 100%;
        }

        .heart::after {
            left: 0;
            top: 0;
            transform: rotate(45deg);
            transform-origin: 100% 100%;
        }

        /* Floating hearts */
        .floating-hearts {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
        }

        .floating-heart {
            position: absolute;
            font-size: 20px;
            animation: floatUp 4s ease-in-out infinite;
            opacity: 0;
        }

        /* Text styles */
        .love-text {
            margin-top: 20px;
            color: white;
            text-align: center;
        }

        .title {
            font-size: 2.5em;
            background: linear-gradient(45deg, #ff6b9d, #ff1744, #ff6b9d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 15px;
            animation: textGlow 2s ease-in-out infinite;
            font-weight: bold;
        }

        .subtitle {
            font-size: 1.2em;
            color: #ff6b9d;
            margin: 10px 0;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(255, 107, 157, 0.8);
        }

        .date-display {
            font-size: 1.4em;
            color: #ff9800;
            margin: 15px 0;
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 107, 157, 0.3);
            display: inline-block;
        }

        .countdown {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
            flex-wrap: wrap;
        }

        .countdown-item {
            background: rgba(255, 255, 255, 0.1);
            padding: 15px 25px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 107, 157, 0.2);
            min-width: 100px;
        }

        .countdown-number {
            font-size: 2em;
            color: #ff6b9d;
            font-weight: bold;
            display: block;
        }

        .countdown-label {
            font-size: 0.9em;
            color: #ccc;
            margin-top: 5px;
        }

        /* Buttons */
        .buttons-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
            margin: 30px 0;
        }

        .btn {
            padding: 12px 25px;
            font-size: 1em;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            font-weight: bold;
            letter-spacing: 1px;
            outline: none;
            text-decoration: none;
            display: inline-block;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn:active {
            transform: scale(0.95);
        }

        .btn-love {
            background: linear-gradient(45deg, #ff1744, #ff6b9d);
            color: white;
            box-shadow: 0 5px 15px rgba(255, 23, 68, 0.4);
        }

        .btn-memory {
            background: linear-gradient(45deg, #ff9800, #ff5722);
            color: white;
            box-shadow: 0 5px 15px rgba(255, 152, 0, 0.4);
        }

        .btn-message {
            background: linear-gradient(45deg, #9c27b0, #e91e63);
            color: white;
            box-shadow: 0 5px 15px rgba(156, 39, 176, 0.4);
        }

        .btn-share {
            background: linear-gradient(45deg, #2196f3, #00bcd4);
            color: white;
            box-shadow: 0 5px 15px rgba(33, 150, 243, 0.4);
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }

        /* Modal styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.9);
            animation: fadeIn 0.3s ease;
        }

        .modal-content {
            position: relative;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            margin: 5% auto;
            padding: 30px;
            border-radius: 20px;
            width: 90%;
            max-width: 600px;
            text-align: center;
            color: white;
            border: 2px solid #ff6b9d;
            box-shadow: 0 0 50px rgba(255, 107, 157, 0.5);
            animation: slideDown 0.5s ease;
            max-height: 80vh;
            overflow-y: auto;
        }

        .close {
            position: absolute;
            right: 20px;
            top: 15px;
            font-size: 30px;
            font-weight: bold;
            color: #ff6b9d;
            cursor: pointer;
            transition: all 0.3s;
        }

        .close:hover {
            color: #ff1744;
            transform: scale(1.2);
        }

        .modal-icon {
            font-size: 4em;
            margin-bottom: 20px;
            animation: bounceIcon 1s infinite;
        }

        .message-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
            color: #ff6b9d;
            font-size: 1.2em;
            line-height: 1.8;
        }

        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .gallery-item {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 10px;
            font-size: 2em;
            transition: transform 0.3s;
        }

        .gallery-item:hover {
            transform: scale(1.1);
            background: rgba(255, 107, 157, 0.2);
        }

        /* Toast */
        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(45deg, #ff1744, #ff6b9d);
            color: white;
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 1.1em;
            z-index: 2000;
            animation: slideDownToast 0.5s ease, fadeOutToast 0.5s ease 2.5s forwards;
            box-shadow: 0 10px 30px rgba(255, 23, 68, 0.5);
        }

        /* Animations */
        @keyframes heartBeat {
            0%, 100% { transform: scale(1); }
            15% { transform: scale(1.15); }
            30% { transform: scale(1); }
            45% { transform: scale(1.1); }
            60% { transform: scale(1); }
        }

        @keyframes textGlow {
            0%, 100% { filter: brightness(1); }
            50% { filter: brightness(1.3); }
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }

        @keyframes floatUp {
            0% { transform: translateY(0) rotate(0deg); opacity: 0; }
            50% { opacity: 1; }
            100% { transform: translateY(-200px) rotate(360deg); opacity: 0; }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes slideDown {
            from { transform: translateY(-100px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @keyframes bounceIcon {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        @keyframes fadeOut {
            to { opacity: 0; visibility: hidden; }
        }

        @keyframes slideDownToast {
            from { transform: translate(-50%, -100px); opacity: 0; }
            to { transform: translate(-50%, 0); opacity: 1; }
        }

        @keyframes fadeOutToast {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        @keyframes loadingPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.3); }
        }

        /* Love explosion */
        .love-particle {
            position: fixed;
            pointer-events: none;
            z-index: 999;
            animation: particleExplode 1s ease-out forwards;
        }

        @keyframes particleExplode {
            0% { transform: translate(0, 0) scale(1); opacity: 1; }
            100% { transform: translate(var(--tx), var(--ty)) scale(0); opacity: 0; }
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #1a1a2e;
        }

        ::-webkit-scrollbar-thumb {
            background: #ff6b9d;
            border-radius: 4px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .heart {
                width: 150px;
                height: 150px;
            }
            
            .heart::before,
            .heart::after {
                width: 75px;
                height: 120px;
            }
            
            .title {
                font-size: 1.8em;
            }
            
            .subtitle {
                font-size: 1em;
            }
            
            .buttons-container {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 80%;
                max-width: 300px;
            }
            
            .countdown {
                gap: 10px;
            }
            
            .countdown-item {
                padding: 10px 15px;
                min-width: 80px;
            }
        }
    </style>
</head>
<body>
    <!-- Loading Screen -->
    <div class="loading-screen">
        <div class="loading-heart">💕</div>
    </div>

    <!-- Stars Background -->
    <div class="stars" id="stars"></div>

    <div class="container">
        <!-- Floating Hearts -->
        <div class="floating-hearts" id="floatingHearts"></div>

        <!-- Main Heart -->
        <div class="heart-wrapper">
            <div class="heart" id="mainHeart" title="Nhấn vào đây nè! 💕"></div>
        </div>

        <!-- Text Content -->
        <div class="love-text">
            <h1 class="title">💕 Kỷ Niệm 2 Năm 💕</h1>
            <p class="subtitle" id="loveMessage">Chúc mừng ngày đặc biệt của chúng ta!</p>
            
            <div class="date-display">
                📅 24/04/2024 - 24/04/2026
            </div>

            <!-- Countdown -->
            <div class="countdown">
                <div class="countdown-item">
                    <span class="countdown-number" id="days">0</span>
                    <span class="countdown-label">Ngày</span>
                </div>
                <div class="countdown-item">
                    <span class="countdown-number" id="hours">0</span>
                    <span class="countdown-label">Giờ</span>
                </div>
                <div class="countdown-item">
                    <span class="countdown-number" id="minutes">0</span>
                    <span class="countdown-label">Phút</span>
                </div>
                <div class="countdown-item">
                    <span class="countdown-number" id="seconds">0</span>
                    <span class="countdown-label">Giây</span>
                </div>
            </div>

            <!-- Buttons -->
            <div class="buttons-container">
                <button class="btn btn-love" onclick="sendLove()">
                    💝 Gửi Yêu Thương
                </button>
                
                <button class="btn btn-memory" onclick="showMemories()">
                    📸 Kỷ Niệm Đẹp
                </button>
                
                <button class="btn btn-message" onclick="showMessage()">
                    💌 Lời Nhắn
                </button>
                
                <button class="btn btn-share" onclick="sharePage()">
                    🔗 Chia Sẻ
                </button>
            </div>
        </div>
    </div>

    <!-- Memories Modal -->
    <div id="memoriesModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal('memoriesModal')">&times;</span>
            <div class="modal-icon">📸</div>
            <h2>Album Kỷ Niệm</h2>
            <div class="gallery">
                <div class="gallery-item">💑</div>
                <div class="gallery-item">🌹</div>
                <div class="gallery-item">💕</div>
                <div class="gallery-item">🎉</div>
                <div class="gallery-item">🌟</div>
                <div class="gallery-item">💝</div>
            </div>
            <p style="color: #ff6b9d; margin: 20px 0;">Những khoảnh khắc đẹp nhất của chúng ta!</p>
            <button class="btn btn-love" onclick="closeModal('memoriesModal')">Đóng Lại 💕</button>
        </div>
    </div>

    <!-- Message Modal -->
    <div id="messageModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal('messageModal')">&times;</span>
            <div class="modal-icon">💌</div>
            <h2>Lời Nhắn Yêu Thương</h2>
            <div class="message-box">
                <p>Gửi người thương yêu,</p>
                <p style="margin: 15px 0;">
                    Cảm ơn em/anh đã đến bên anh/em. 2 năm qua là khoảng thời gian 
                    tuyệt vời nhất cuộc đời anh/em. Chúng ta đã cùng nhau trải qua 
                    bao niềm vui, nỗi buồn và cả những kỷ niệm không thể nào quên.
                </p>
                <p>
                    Anh/Em yêu em/anh rất nhiều! ❤️<br>
                    Mãi bên nhau em/anh nhé!
                </p>
            </div>
            <button class="btn btn-message" onclick="closeModal('messageModal')">Yêu Thương 💕</button>
        </div>
    </div>

    <script>
        // Create stars
        function createStars() {
            const starsContainer = document.getElementById('stars');
            for (let i = 0; i < 100; i++) {
                const star = document.createElement('div');
                star.classList.add('star');
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDelay = Math.random() * 2 + 's';
                star.style.width = Math.random() * 3 + 'px';
                star.style.height = star.style.width;
                starsContainer.appendChild(star);
            }
        }

        // Create floating hearts
        function createFloatingHearts() {
            const container = document.getElementById('floatingHearts');
            setInterval(() => {
                const heart = document.createElement('span');
                heart.classList.add('floating-heart');
                heart.textContent = ['💕', '❤️', '💖', '💗', '💝'][Math.floor(Math.random() * 5)];
                heart.style.left = Math.random() * 100 + '%';
                heart.style.animationDuration = Math.random() * 3 + 3 + 's';
                heart.style.fontSize = Math.random() * 20 + 15 + 'px';
                container.appendChild(heart);
                
                setTimeout(() => heart.remove(), 4000);
            }, 500);
        }

        // Update countdown
        function updateCountdown() {
            const startDate = new Date('2024-04-24');
            const now = new Date();
            const diff = now - startDate;

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);

            document.getElementById('days').textContent = days;
            document.getElementById('hours').textContent = hours;
            document.getElementById('minutes').textContent = minutes;
            document.getElementById('seconds').textContent = seconds;
        }

        // Random love messages
        const loveMessages = [
            "Chúc mừng ngày đặc biệt của chúng ta! 💕",
            "2 năm yêu thương và hạnh phúc! 🌟",
            "Mỗi ngày bên em/anh là một món quà! 🎁",
            "Tình yêu của chúng ta ngày càng lớn! 💖",
            "Cảm ơn em/anh đã đến bên anh/em! 💝"
        ];

        // Send love effect
        function sendLove() {
            // Create explosion effect
            for (let i = 0; i < 30; i++) {
                const particle = document.createElement('span');
                particle.classList.add('love-particle');
                particle.textContent = ['💕', '❤️', '💖', '💗', '💝', '✨', '🌟'][Math.floor(Math.random() * 7)];
                
                const angle = (Math.PI * 2 * i) / 30;
                const distance = 100 + Math.random() * 200;
                const tx = Math.cos(angle) * distance;
                const ty = Math.sin(angle) * distance;
                
                particle.style.setProperty('--tx', tx + 'px');
                particle.style.setProperty('--ty', ty + 'px');
                particle.style.left = '50%';
                particle.style.top = '50%';
                particle.style.fontSize = (20 + Math.random() * 30) + 'px';
                
                document.body.appendChild(particle);
                setTimeout(() => particle.remove(), 1000);
            }
            
            // Change message
            document.getElementById('loveMessage').textContent = 
                loveMessages[Math.floor(Math.random() * loveMessages.length)];
            
            showToast('💕 Yêu em/anh nhiều lắm! 💕');
        }

        // Show modals
        function showMemories() {
            document.getElementById('memoriesModal').style.display = 'block';
        }

        function showMessage() {
            document.getElementById('messageModal').style.display = 'block';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }

        // Share page
        function sharePage() {
            if (navigator.share) {
                navigator.share({
                    title: '💕 Kỷ Niệm 2 Năm Yêu Nhau',
                    text: 'Chúng tôi đã bên nhau được 2 năm rồi! 💕',
                    url: window.location.href
                }).catch(console.error);
            } else {
                // Fallback: copy to clipboard
                navigator.clipboard.writeText(window.location.href).then(() => {
                    showToast('🔗 Link đã được sao chép!');
                });
            }
        }

        // Toast notification
        function showToast(message) {
            const oldToast = document.querySelector('.toast');
            if (oldToast) oldToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => toast.remove(), 3000);
        }

        // Close modals on outside click
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.style.display = 'none';
            }
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', function(event) {
            switch(event.key.toLowerCase()) {
                case 'l': sendLove(); break;
                case 'm': showMemories(); break;
                case 'n': showMessage(); break;
                case 's': sharePage(); break;
            }
        });

        // Main heart click
        document.getElementById('mainHeart').addEventListener('click', sendLove);

        // Initialize
        createStars();
        createFloatingHearts();
        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
</body>
</html>
